{
  "expo": {
    "name": "Padoka 100%",
    "slug": "padoka100",
    "owner": "padoka",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "padoka100",
    "userInterfaceStyle": "light",
    "runtimeVersion": "exposdk:54.0.0",
    "updates": {
      "url": "https://u.expo.dev/1e644724-8f8e-46db-9ddb-c6f1a6cfcfa4"
