# O app mobile usa app.json/extra para URLs publicas.
# Em desenvolvimento, altere expo.extra.apiLocalUrl em app.json se precisar apontar
# para o IP da sua maquina na rede local, por exemplo http://192.168.0.10:8000.

# Supabase Auth usa chaves publicas no cliente. Preencha no ambiente de build
# ou em expo.extra para habilitar login, cadastro, recuperacao e Google.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Chave publica/compartilhada que o backend legado ainda exige em X-API-Key.
EXPO_PUBLIC_API_KEY=
