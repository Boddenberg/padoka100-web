{
  "name": "padoka100-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "App mobile Expo da Padoka 100.",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "doctor": "expo-doctor",
    "update:preview": "npx eas-cli update --branch preview --message \"Padoka 100 mobile update\" --platform android",
    "update:production": "npx eas-cli update --branch production --message \"Padoka 100 mobile update\" --platform android",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@expo-google-fonts/nunito": "^0.4.2",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
