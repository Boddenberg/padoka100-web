{
  "name": "padoka100-web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.6.2",
  "description": "Frontend PWA da Padoka 100.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:mobile": "node scripts/build-mobile.mjs",
    "cap:sync:android": "node scripts/patch-capacitor-android-java.mjs && npm run build:mobile && npx cap sync android",
    "eas-build-post-install": "npm run cap:sync:android",
    "start": "node scripts/serve.mjs",
    "preview": "vite preview",
    "lint": "eslint ."
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Boddenberg/padoka100-web.git"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "type": "module",
  "bugs": {
    "url": "https://github.com/Boddenberg/padoka100-web/issues"
  },
  "homepage": "https://github.com/Boddenberg/padoka100-web#readme",
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.101.2",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "react-router-dom": "^7.18.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^7.2.6",
    "vite-plugin-pwa": "^1.3.0"
  }
}
