    "@tanstack/react-query": "5.101.2",
    "expo": "57.0.2",
    "expo-asset": "~57.0.3",
    "expo-audio": "57.0.0",
    "expo-constants": "57.0.3",
    "expo-font": "~57.0.0",
    "expo-haptics": "~15.0.8",
    "expo-image": "57.0.0",
    "expo-image-picker": "57.0.2",
    "expo-linear-gradient": "~57.0.0",
    "expo-linking": "~57.0.1",
    "expo-router": "57.0.3",
    "expo-secure-store": "57.0.0",
