{
  "name": "padoka100-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "App mobile Expo da Padoka 100.",
  "main": "expo-router/entry",
  "scripts": {
    "start": "node scripts/start.mjs",
    "start:mobile": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "npm run build:web",
    "build:web": "expo export --platform web",
    "start:web": "node scripts/serve-web.mjs",
    "doctor": "expo-doctor",
    "update:preview": "npx eas-cli update --branch preview --environment preview --message \"Padoka 100 mobile update\"",
    "update:production": "npx eas-cli update --branch production --environment production --message \"Padoka 100 mobile update\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@expo-google-fonts/nunito": "^0.4.2",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.110.2",
    "@tanstack/react-query": "5.101.2",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.18",
    "expo-web-browser": "~15.0.11",
    "lucide-react-native": "1.23.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "babel-plugin-module-resolver": "5.0.3",
    "babel-preset-expo": "~54.0.10",
    "eslint": "9.39.4",
    "eslint-config-expo": "~10.0.0",
    "expo-doctor": "1.20.0",
    "typescript": "~5.9.2"
  }
}
